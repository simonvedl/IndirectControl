Cell[CellGroupData[{

Cell["Detuned initial state |+><+| against ZZ coupling", "Subsubsection",
 CellChangeTimes->{{3.9832099469500027`*^9, 3.983209971337426*^9}, {
  3.983210002778914*^9, 
  3.98321000990663*^9}},ExpressionUUID->"51456944-4823-45e5-90f1-\
e52aa2f83999"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Omega]", "=", "1000"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalDelta]\[Omega]", "=", "1"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"rhoIn", "=", 
      RowBox[{
       RowBox[{"rhoQubit", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}], "]"}], "\[TensorProduct]", 
       
       RowBox[{"rhoQubit", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0"}], "}"}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"rhoFin", "=", 
      RowBox[{"rhoQubit", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1"}], "}"}], "]"}]}]}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"t", "=", 
     RowBox[{"5", "\[CapitalDelta]\[Omega]"}]}], "\[IndentingNewLine]", "}"}],
    ",", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{"contours", "=", 
     RowBox[{"Range", "[", 
      RowBox[{"0", ",", "1", ",", ".05"}], "]"}]}], "\[IndentingNewLine]", 
    "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"fun1", "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Gamma]", ",", "z"}], "}"}], "|->", 
       RowBox[{
        RowBox[{"CachedUnitaryStrategy", "[", 
         RowBox[{"rhoIn", ",", "rhoFin", ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "t", ",", "t"}], "}"}], ",", 
          RowBox[{"Hamiltonian", "[", 
           RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
               RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
               RowBox[{"z", " ", "\[CapitalDelta]\[Omega]"}]}], "}"}], 
             "]"}]}], "]"}]}], "]"}], "[", "\"\<Population\>\"", "]"}]}]}], ",",
      "\[IndentingNewLine]", 
     RowBox[{"fun2", "=", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Gamma]", ",", "z"}], "}"}], "|->", 
       RowBox[{
        RowBox[{"CachedSDPResult", "[", 
         RowBox[{"rhoIn", ",", "rhoFin", ",", 
          RowBox[{"{", 
           RowBox[{"t", ",", "t", ",", "t"}], "}"}], ",", 
          RowBox[{"Hamiltonian", "[", 
           RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
            RowBox[{"DiagonalMatrix", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
               RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
               RowBox[{"z", " ", "\[CapitalDelta]\[Omega]"}]}], "}"}], 
             "]"}]}], "]"}]}], "]"}], "[", "\"\<Population\>\"", "]"}]}]}]}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ParallelDensityPlotData", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Abs", "[", 
        RowBox[{
         RowBox[{"fun2", "[", "##", "]"}], "-", 
         RowBox[{"fun1", "[", "##", "]"}]}], "]"}], "&"}], ",", 
      RowBox[{"{", 
       RowBox[{"\[Gamma]", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"{", 
       RowBox[{"z", ",", "0", ",", "1"}], "}"}], ",", 
      RowBox[{"\"\<MaxIters\>\"", "->", "4"}]}], "]"}], "//", 
    RowBox[{
     RowBox[{"ListDensityPlot", "[", 
      RowBox[{"#", ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRangePadding", "->", "None"}], ",", "\[IndentingNewLine]", 
       RowBox[{"Mesh", "->", 
        RowBox[{"{", "contours", "}"}]}], ",", 
       RowBox[{"MeshFunctions", "->", 
        RowBox[{"{", 
         RowBox[{"#3", "&"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"PlotRange", "->", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0.3"}], "}"}]}], ",", "\[IndentingNewLine]", 
       RowBox[{"ColorFunction", "->", "\"\<LightTemperatureMap\>\""}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"ClippingStyle", "->", 
        RowBox[{"{", 
         RowBox[{"Yellow", ",", "Green"}], "}"}]}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{"GridLines", "->", "Automatic"}], ",", "\[IndentingNewLine]", 
