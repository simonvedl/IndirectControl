Cell[BoxData[{
 RowBox[{
  RowBox[{"ClearAll", "[", "CachedSDPResult", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SetAttributes", "[", 
   RowBox[{"CachedSDPResult", ",", "HoldAll"}], "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"CachedSDPResult", "[", 
    RowBox[{"rhoIn_", ",", "rhoFin_", ",", 
     RowBox[{"t_", "?", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{"VectorQ", "[", 
         RowBox[{"#", ",", "NumericQ"}], "]"}], "&"}], ")"}]}], ",", 
     RowBox[{"HoldPattern", "[", 
      RowBox[{"Hamiltonian", "[", 
       RowBox[{"\[Omega]_", ",", "\[CapitalDelta]\[Omega]_", ",", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"XX_", "?", "NumericQ"}], ",", 
           RowBox[{"YY_", "?", "NumericQ"}], ",", "ZZ_"}], "}"}], "]"}]}], 
       "]"}], "]"}]}], "]"}], ":=", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"CachedSDPResult", "[", 
     RowBox[{"rhoIn", ",", "rhoFin", ",", "t", ",", 
      RowBox[{"Hamiltonian", "[", 
       RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"XX", ",", "YY", ",", "ZZ"}], "}"}], "]"}]}], "]"}]}], 
     "]"}], "=", 
    RowBox[{"SDPResult", "[", 
     RowBox[{"rhoIn", ",", "rhoFin", ",", 
      RowBox[{"Evaluate", "[", 
       RowBox[{"N", "[", "t", "]"}], "]"}], ",", 
      RowBox[{"Hamiltonian", "[", 
       RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
        RowBox[{"DiagonalMatrix", "[", 
         RowBox[{"{", 
          RowBox[{"XX", ",", "YY", ",", "ZZ"}], "}"}], "]"}]}], "]"}]}], 
     "]"}]}]}], ";"}]}], "Input",
