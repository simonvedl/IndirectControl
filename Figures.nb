5221c7b501b9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"With", "[", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"\[Omega]", "=", "1000"}], ",", "\[IndentingNewLine]", 
     RowBox[{"\[CapitalDelta]\[Omega]", "=", "1"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"rhoFin", "=", 
      RowBox[{"rhoQubit", "[", 
       RowBox[{"{", 
        RowBox[{"0", ",", "0", ",", "1"}], "}"}], "]"}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"rhoIn", "=", 
      RowBox[{
       RowBox[{"rhoQubit", "[", 
        RowBox[{"{", 
         RowBox[{"0", ",", "0", ",", "0"}], "}"}], "]"}], "\[TensorProduct]", 
       
       RowBox[{"rhoQubit", "[", 
        RowBox[{"{", 
         RowBox[{"1", ",", "0", ",", "0"}], "}"}], "]"}]}]}]}], 
    "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
   RowBox[{"{", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"t", "=", 
      RowBox[{"5", "\[CapitalDelta]\[Omega]"}]}], ",", "\[IndentingNewLine]", 
     
     RowBox[{"plottingRange", "=", 
      RowBox[{"{", 
       RowBox[{"\[Gamma]", ",", "0", ",", "1", ",", 
        RowBox[{"10", "^", 
         RowBox[{"-", "3"}]}]}], "}"}]}]}], "\[IndentingNewLine]", "}"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"fun1", "=", 
      RowBox[{"\[Gamma]", "|->", 
       RowBox[{"CachedSDPResult", "[", 
        RowBox[{"rhoIn", ",", "rhoFin", ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "t", ",", "t"}], "}"}], ",", 
         RowBox[{"Hamiltonian", "[", 
          RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
              RowBox[{"\[Gamma]", " ", "\[CapitalDelta]\[Omega]"}], ",", 
              "0"}], "}"}], "]"}]}], "]"}]}], "]"}]}]}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"fun2", "=", 
      RowBox[{"\[Gamma]", "|->", 
       RowBox[{"CachedUnitaryStrategy", "[", 
        RowBox[{"rhoIn", ",", "rhoFin", ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "t", ",", "t"}], "}"}], ",", 
         RowBox[{"Hamiltonian", "[", 
          RowBox[{"\[Omega]", ",", "\[CapitalDelta]\[Omega]", ",", 
           RowBox[{"DiagonalMatrix", "[", 
            RowBox[{"{", 
             RowBox[{
